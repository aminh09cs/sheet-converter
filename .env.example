# ===== App =====
# development | staging | production
APP_ENV=development
HOST=127.0.0.1
PORT=8001
RELOAD=true
LOG_LEVEL=info

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Production: đổi sang domain thật, vd https://app.example.com/auth/callback
OAUTH_REDIRECT_URI=http://127.0.0.1:8001/auth/callback

# ===== Session =====
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=replace-this-with-a-long-random-string

# ===== Storage =====
# Default: ~/.sheet-converter/tokens.json
# Production: mount persistent volume, vd /var/lib/sheet-converter/tokens.json
# TOKEN_STORE_PATH=/var/lib/sheet-converter/tokens.json

# ===== Supabase (saved mapping templates) =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_secret_or_anon_key
